{#
  Renders an input-first combobox component.

  @param id {string} [optional] - Unique identifier for the combobox component.
  @param selected {string|array} [optional] - The initially selected value(s).
  @param name {string} [optional] - The name attribute for the hidden input storing the selected value.
  @param multiple {boolean} [optional] [default=false] - Enables multiple selection mode with chips.
  @param placeholder {string} [optional] - Placeholder text for the visible input.
  @param close_on_select {boolean} [optional] [default=false] - Closes the popover when selecting an option in multiple mode.
  @param clear {boolean} [optional] [default=false] - Shows a clear button in single-select mode.
  @param auto_highlight {boolean} [optional] [default=false] - Highlights the first matching option while filtering.
  @param format {string} [optional] [default="value"] - Hidden input serialization format: "value" or "object".
  @param main_attrs {object} [optional] - Additional HTML attributes for the root div.
  @param input_attrs {object} [optional] - Additional HTML attributes for the visible input.
  @param popover_attrs {object} [optional] - Additional HTML attributes for the popover div.
  @param listbox_attrs {object} [optional] - Additional HTML attributes for the listbox div.
  @param hidden_input_attrs {object} [optional] - Additional HTML attributes for the hidden input.
#}
{% macro combobox(
  id=None,
  selected=None,
  name=None,
  multiple=false,
  placeholder=None,
  close_on_select=false,
  clear=false,
  auto_highlight=false,
  format="value",
  main_attrs={},
  input_attrs={},
  popover_attrs={},
  listbox_attrs={},
  hidden_input_attrs={}
) %}
{% set id = id or ("combobox-" + (range(100000, 999999) | random | string)) %}
{% set selected_values = [] %}
{% set selected_entries = [] %}
{% if selected is defined and selected is iterable and selected is not string %}
  {% for item in selected %}
    {% if item.value is defined %}
      {% set selected_values = (selected_values.push(item.value), selected_values) %}
      {% set selected_entries = (selected_entries.push({ value: item.value, label: (item.label if item.label is defined else item.value) }), selected_entries) %}
    {% else %}
      {% set selected_values = (selected_values.push(item), selected_values) %}
      {% set selected_entries = (selected_entries.push({ value: item, label: item }), selected_entries) %}
    {% endif %}
  {% endfor %}
{% elif selected is defined and selected %}
  {% if selected.value is defined %}
    {% set selected_values = [selected.value] %}
    {% set selected_entries = [{ value: selected.value, label: (selected.label if selected.label is defined else selected.value) }] %}
  {% else %}
    {% set selected_values = [selected] %}
    {% set selected_entries = [{ value: selected, label: selected }] %}
  {% endif %}
{% endif %}
{% set hidden_value = ((selected_entries | dump if multiple else ((selected_entries[0] if selected_entries[0] else None) | dump)) if format == "object" else (selected_values | dump if multiple else (selected_values[0] if selected_values[0] else ''))) %}

<div
  id="{{ id }}"
  class="combobox {{ main_attrs.class }}"
  {% if format == "object" %}data-format="object"{% endif %}
  {% if multiple and close_on_select %}data-close-on-select="true"{% endif %}
  {% if auto_highlight %}data-auto-highlight="true"{% endif %}
  {% for key, value in main_attrs %}
    {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
  {% endfor %}
>
  {% if multiple %}
  <input
    type="text"
    role="combobox"
    class="{{ input_attrs.class }}"
    placeholder="{{ placeholder or '' }}"
    autocomplete="off"
    autocorrect="off"
    spellcheck="false"
    aria-autocomplete="list"
    aria-expanded="false"
    aria-controls="{{ id }}-listbox"
    {% for key, value in input_attrs %}
      {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
    {% endfor %}
  >
  {% elif clear %}
  <div class="input-group {{ input_attrs.class }}">
    <input
      type="text"
      role="combobox"
      placeholder="{{ placeholder or '' }}"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls="{{ id }}-listbox"
      {% for key, value in input_attrs %}
        {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
      {% endfor %}
    >
    <span role="group" data-align="inline-end">
      <button type="button" data-clear aria-label="Clear selection">
        <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <button type="button" class="btn" data-variant="ghost" data-size="icon-xs" aria-label="Open suggestions" aria-haspopup="listbox" aria-expanded="false" aria-controls="{{ id }}-listbox">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
    </span>
  </div>
  {% else %}
  <input
    type="text"
    role="combobox"
    placeholder="{{ placeholder or '' }}"
    autocomplete="off"
    autocorrect="off"
    spellcheck="false"
    aria-autocomplete="list"
    aria-expanded="false"
    aria-controls="{{ id }}-listbox"
    class="{{ input_attrs.class }}"
    {% for key, value in input_attrs %}
      {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
    {% endfor %}
  >
  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="combobox-trigger-icon"><path d="m6 9 6 6 6-6"/></svg>
  {% endif %}
  <div
    id="{{ id }}-popover"
    data-popover
    aria-hidden="true"
    {% for key, value in popover_attrs %}
      {{ key }}="{{ value }}"
    {% endfor %}
  >
    <div
      role="listbox"
      id="{{ id }}-listbox"
      aria-orientation="vertical"
      {% if multiple %}aria-multiselectable="true"{% endif %}
      {% for key, value in listbox_attrs %}
        {{ key }}="{{ value }}"
      {% endfor %}
    >
      {{ caller() if caller else '' }}
    </div>
  </div>
  <input
    type="hidden"
    {% if name %}name="{{ name }}"{% endif %}
    value='{{ hidden_value }}'
    {% for key, value in hidden_input_attrs %}
      {{ key }}="{{ value }}"
    {% endfor %}
  >
</div>
{% endmacro %}
