{#
  Renders an input-first combobox component.
#}
{% macro combobox(
  id=None,
  selected=None,
  name=None,
  multiple=false,
  placeholder=None,
  close_on_select=false,
  clear=false,
  auto_highlight=false,
  format="value",
  main_attrs={},
  input_attrs={},
  popover_attrs={},
  listbox_attrs={},
  hidden_input_attrs={}
) %}
{% set id = id or ("combobox-" + (range(100000, 999999) | random | string)) %}
{% set main_attrs = main_attrs or {} %}
{% set input_attrs = input_attrs or {} %}
{% set popover_attrs = popover_attrs or {} %}
{% set listbox_attrs = listbox_attrs or {} %}
{% set hidden_input_attrs = hidden_input_attrs or {} %}
{% set selected_entries = namespace(items=[]) %}
{% if selected is defined and selected is iterable and selected is not string %}
  {% set selected_values = selected %}
  {% for item in selected %}
    {% if item.value is defined %}
      {% set selected_entries.items = selected_entries.items + [{'value': item.value, 'label': item.label if item.label is defined else item.value}] %}
    {% else %}
      {% set selected_entries.items = selected_entries.items + [{'value': item, 'label': item}] %}
    {% endif %}
  {% endfor %}
{% elif selected is defined and selected %}
  {% if selected.value is defined %}
    {% set selected_values = [selected.value] %}
    {% set selected_entries.items = [{'value': selected.value, 'label': selected.label if selected.label is defined else selected.value}] %}
  {% else %}
    {% set selected_values = [selected] %}
    {% set selected_entries.items = [{'value': selected, 'label': selected}] %}
  {% endif %}
{% else %}
  {% set selected_values = [] %}
{% endif %}
{% set hidden_value = ((selected_entries.items | tojson if multiple else ((selected_entries.items[0] if selected_entries.items else none) | tojson)) if format == "object" else (selected_values | tojson if multiple else (selected_values[0] if selected_values else ''))) %}

<div
  id="{{ id }}"
  class="combobox {{ main_attrs.class | default('') }}"
  {% if format == "object" %}data-format="object"{% endif %}
  {% if multiple and close_on_select %}data-close-on-select="true"{% endif %}
  {% if auto_highlight %}data-auto-highlight="true"{% endif %}
  {% for key, value in main_attrs.items() %}
    {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
  {% endfor %}
>
  {% if multiple %}
  <input
    type="text"
    role="combobox"
    class="{{ input_attrs.class | default('') }}"
    placeholder="{{ placeholder or '' }}"
    autocomplete="off"
    autocorrect="off"
    spellcheck="false"
    aria-autocomplete="list"
    aria-expanded="false"
    aria-controls="{{ id }}-listbox"
    {% for key, value in input_attrs.items() %}
      {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
    {% endfor %}
  >
  {% elif clear %}
  <div class="input-group {{ input_attrs.class | default('') }}">
    <input
      type="text"
      role="combobox"
      placeholder="{{ placeholder or '' }}"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls="{{ id }}-listbox"
      {% for key, value in input_attrs.items() %}
        {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
      {% endfor %}
    >
    <span role="group" data-align="inline-end">
      <button type="button" data-clear aria-label="Clear selection">
        <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <button type="button" class="btn" data-variant="ghost" data-size="icon-xs" aria-label="Open suggestions" aria-haspopup="listbox" aria-expanded="false" aria-controls="{{ id }}-listbox">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
    </span>
  </div>
  {% else %}
  <input
    type="text"
    role="combobox"
    placeholder="{{ placeholder or '' }}"
    autocomplete="off"
    autocorrect="off"
    spellcheck="false"
    aria-autocomplete="list"
    aria-expanded="false"
    aria-controls="{{ id }}-listbox"
    class="{{ input_attrs.class | default('') }}"
    {% for key, value in input_attrs.items() %}
      {% if key != 'class' %}{{ key }}="{{ value }}"{% endif %}
    {% endfor %}
  >
  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="combobox-trigger-icon"><path d="m6 9 6 6 6-6"/></svg>
  {% endif %}
  <div
    id="{{ id }}-popover"
    data-popover
    aria-hidden="true"
    {% for key, value in popover_attrs.items() %}
      {{ key }}="{{ value }}"
    {% endfor %}
  >
    <div
      role="listbox"
      id="{{ id }}-listbox"
      aria-orientation="vertical"
      {% if multiple %}aria-multiselectable="true"{% endif %}
      {% for key, value in listbox_attrs.items() %}
        {{ key }}="{{ value }}"
      {% endfor %}
    >
      {{ caller() if caller is defined else '' }}
    </div>
  </div>
  <input
    type="hidden"
    {% if name %}name="{{ name }}"{% endif %}
    value='{{ hidden_value }}'
    {% for key, value in hidden_input_attrs.items() %}
      {{ key }}="{{ value }}"
    {% endfor %}
  >
</div>
{% endmacro %}
