                        <input class="input" type="radio" name="fruit" aria-label="Banana" />
                      </div>
                      <div class="flex gap-3">
                        <input class="input" type="checkbox" aria-label="Enable email alerts" checked />
                        <input class="input hidden min-[1900px]:flex" type="checkbox" aria-label="Enable push alerts" />
                      </div>
                      <input class="input flex min-[1900px]:hidden" type="checkbox" role="switch" aria-label="Enable compact notifications" checked />
                    </div>
                    <div class="flex flex-wrap items-center gap-3">
                      <button class="btn" data-variant="outline" type="button" onclick="document.getElementById('landing-alert-dialog').showModal()">Alert Dialog</button>
                      <div class="button-group ml-auto max-w-full">
                        <button class="btn min-w-0" data-variant="outline" type="button"><span class="truncate">Button Group</span></button>
                        <div id="landing-quick-actions" class="dropdown-menu">
                          <button id="landing-quick-actions-trigger" class="btn" data-size="icon" data-variant="outline" type="button" aria-label="Open quick actions" aria-haspopup="menu" aria-controls="landing-quick-actions-menu" aria-expanded="false"><Fragment set:html={ChevronUp} /></button>
                          <div id="landing-quick-actions-popover" data-popover data-side="top" data-align="end" aria-hidden="true" class="w-40">
