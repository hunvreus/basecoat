---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (() => {
        const media = matchMedia("(prefers-color-scheme: dark)");
        const getStoredTheme = () => {
          try {
            return localStorage.getItem("themeMode");
          } catch (_) {
            return null;
          }
        };
        const syncTheme = () => {
          const stored = getStoredTheme();
          document.documentElement.classList.toggle("dark", stored ? stored === "dark" : media.matches);
        };
        try {
          syncTheme();
        } catch (_) {}
        media.addEventListener("change", () => {
          if (!getStoredTheme()) syncTheme();
        });
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          if (mode === "system") {
            try {
              localStorage.removeItem("themeMode");
            } catch (_) {}
            syncTheme();
            return;
          }
          const dark = mode === "dark" || (!mode && !document.documentElement.classList.contains("dark"));
          document.documentElement.classList.toggle("dark", dark);
          try {
            localStorage.setItem("themeMode", dark ? "dark" : "light");
          } catch (_) {}
          document.dispatchEvent(new CustomEvent("basecoat:themechange", { detail: { mode: dark ? "dark" : "light" } }));
        });
      })();
    </script>
    <StyleHead />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Basecoat</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Basecoat`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage.src} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Basecoat`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage.src} />
    <script src={basecoatJsUrl} defer></script>
  </head>
  <body class="min-h-dvh overflow-x-clip bg-background text-foreground antialiased">
    <CommandDialog />
    <header class="bg-background sticky inset-x-0 top-0 isolate z-30 flex shrink-0 items-center gap-2">
      <div class="flex h-14 w-full items-center justify-between gap-2 px-4">
        <div class="flex min-w-0 items-center gap-1">
          <a href="/" class="btn" data-variant="ghost" aria-label="Basecoat home">
            <span class="[&_svg]:size-4" set:html={logoSvg} />
            <span class="truncate font-semibold">Basecoat</span>
          </a>
          <nav class="hidden items-center gap-1 sm:flex" aria-label="Primary">
            <a class="btn" data-variant="ghost" href="/introduction">Docs</a>
            <a class="btn" data-variant="ghost" href="https://github.com/hunvreus/basecoat" target="_blank" rel="noopener">GitHub</a>
            <a class="btn" data-variant="ghost" href="https://basecoatui.com/chat" target="_blank" rel="noopener">Discord</a>
          </nav>
        </div>

        <div class="ml-auto flex min-w-0 flex-1 items-center justify-end gap-2">
          <div
            class="input-group h-8 w-full min-w-0 max-w-72 cursor-text sm:ml-auto"
            role="button"
            tabindex="0"
            aria-label="Search docs"
            onclick="window.rsdOpenCommandSearch?.()"
            onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); window.rsdOpenCommandSearch?.(); }"
          >
            <input type="text" placeholder="Search..." readonly tabindex="-1" aria-hidden="true" />
            <span data-align="start" aria-hidden="true"><Fragment set:html={Search} /></span>
            <span data-align="end" aria-hidden="true"><kbd class="kbd">⌘K</kbd></span>
          </div>
          <select id="style-variant-select" class="select hidden h-8 w-28 shrink-0 text-sm leading-none sm:block" aria-label="Style pack">
            <option value="vega">Vega</option>
            <option value="nova">Nova</option>
            <option value="maia">Maia</option>
            <option value="lyra">Lyra</option>
            <option value="mira">Mira</option>
            <option value="luma">Luma</option>
            <option value="sera">Sera</option>
            <option value="rhea">Rhea</option>
          </select>
          <button
            type="button"
            aria-label="Toggle dark mode"
            data-tooltip="Toggle dark mode"
            data-side="bottom"
            data-align="end"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
            class="btn hidden sm:inline-flex"
            data-size="icon"
            data-variant="ghost"
          >
            <span class="hidden dark:block"><Fragment set:html={Sun} /></span>
            <span class="block dark:hidden"><Fragment set:html={Moon} /></span>
          </button>
        </div>
      </div>
    </header>

