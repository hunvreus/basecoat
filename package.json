{
  "name": "basecoat-css",
  "version": "1.0.1",
  "description": "Tailwind CSS for Basecoat components",
  "author": {
    "name": "hunvreus",
    "url": "https://x.com/hunvreus"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/basecoat.css",
  "style": "dist/basecoat.css",
  "files": [
    "dist/",
    "templates/"
  ],
  "keywords": [
    "components",
    "component library",
    "component system",
    "ui",
    "ui kit",
    "shadcn",
    "shadcn/ui",
    "tailwind",
    "tailwindcss",
    "css",
    "html",
    "jinja",
    "nunjucks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hunvreus/basecoat.git"
  },
  "bugs": {
    "url": "https://github.com/hunvreus/basecoat/issues"
  },
  "homepage": "https://basecoatui.com/installation#npm",
  "exports": {
    ".": "./dist/basecoat.css",
    "./css": "./dist/basecoat.css",
    "./basecoat": "./dist/js/basecoat.js",
    "./basecoat.min": "./dist/js/basecoat.min.js",
    "./all": "./dist/js/all.js",
    "./all.min": "./dist/js/all.min.js",
    "./accordion": "./dist/js/accordion.js",
    "./accordion.min": "./dist/js/accordion.min.js",
    "./chart": "./dist/js/chart.js",
    "./chart.min": "./dist/js/chart.min.js",
    "./combobox": "./dist/js/combobox.js",
    "./combobox.min": "./dist/js/combobox.min.js",
    "./command": "./dist/js/command.js",
    "./command.min": "./dist/js/command.min.js",
    "./dropdown-menu": "./dist/js/dropdown-menu.js",
    "./dropdown-menu.min": "./dist/js/dropdown-menu.min.js",
    "./drawer": "./dist/js/drawer.js",
    "./drawer.min": "./dist/js/drawer.min.js",
    "./popover": "./dist/js/popover.js",
    "./popover.min": "./dist/js/popover.min.js",
    "./range": "./dist/js/range.js",
    "./range.min": "./dist/js/range.min.js",
    "./select": "./dist/js/select.js",
    "./select.min": "./dist/js/select.min.js",
    "./sidebar": "./dist/js/sidebar.js",
    "./sidebar.min": "./dist/js/sidebar.min.js",
    "./tabs": "./dist/js/tabs.js",
    "./tabs.min": "./dist/js/tabs.min.js",
    "./toast": "./dist/js/toast.js",
    "./toast.min": "./dist/js/toast.min.js",
    "./all.css": "./dist/basecoat.all.css",
    "./base": "./dist/basecoat-base.css",
    "./base.css": "./dist/basecoat-base.css",
    "./base.cdn.css": "./dist/basecoat-base.cdn.css",
    "./compat": "./dist/basecoat-compat.css",
    "./compat.css": "./dist/basecoat-compat.css",
    "./compat.cdn.css": "./dist/basecoat-compat.cdn.css",
    "./compat/legacy.css": "./dist/compat/legacy.css",
    "./components": "./dist/basecoat-components.css",
    "./components.css": "./dist/basecoat-components.css",
    "./components/*": "./dist/components/*.css",
    "./components/*.css": "./dist/components/*.css",
    "./base/base.css": "./dist/base/base.css",
    "./vega": "./dist/basecoat-vega.css",
    "./vega.css": "./dist/basecoat-vega.css",
    "./nova": "./dist/basecoat-nova.css",
    "./nova.css": "./dist/basecoat-nova.css",
    "./maia": "./dist/basecoat-maia.css",
    "./maia.css": "./dist/basecoat-maia.css",
    "./lyra": "./dist/basecoat-lyra.css",
    "./lyra.css": "./dist/basecoat-lyra.css",
    "./mira": "./dist/basecoat-mira.css",
    "./mira.css": "./dist/basecoat-mira.css",
    "./luma": "./dist/basecoat-luma.css",
    "./luma.css": "./dist/basecoat-luma.css",
    "./sera": "./dist/basecoat-sera.css",
    "./sera.css": "./dist/basecoat-sera.css",
    "./rhea": "./dist/basecoat-rhea.css",
    "./rhea.css": "./dist/basecoat-rhea.css",
    "./styles/vega": "./dist/styles/vega.css",
    "./styles/nova": "./dist/styles/nova.css",
    "./styles/maia": "./dist/styles/maia.css",
    "./styles/lyra": "./dist/styles/lyra.css",
    "./styles/mira": "./dist/styles/mira.css",
    "./styles/luma": "./dist/styles/luma.css",
    "./styles/sera": "./dist/styles/sera.css",
    "./styles/rhea": "./dist/styles/rhea.css",
    "./styles/*": "./dist/styles/*.css",
    "./styles/*.css": "./dist/styles/*.css",
    "./package.json": "./package.json",
    "./styles/style-vega.css": "./dist/styles/vega.css",
    "./styles/style-nova.css": "./dist/styles/nova.css",
    "./styles/style-maia.css": "./dist/styles/maia.css",
    "./styles/style-lyra.css": "./dist/styles/lyra.css",
    "./styles/style-mira.css": "./dist/styles/mira.css",
    "./styles/style-luma.css": "./dist/styles/luma.css",
    "./styles/style-sera.css": "./dist/styles/sera.css",
    "./styles/style-rhea.css": "./dist/styles/rhea.css",
    "./styles/style-*.css": "./dist/styles/*.css",
    "./templates/nunjucks/*": "./templates/nunjucks/*",
    "./templates/jinja/*": "./templates/jinja/*"
  },
  "scripts": {
    "build": "node ./scripts/build.js",
    "prepack": "node ./scripts/build.js",
    "docs:build": "npm run build && npm --prefix site clean-install --progress=false && npm --prefix site run build",
    "docs:dev": "npm --prefix site run dev",
    "docs:preview": "npm run docs:build && npm --prefix site run preview",
    "workers:dev": "npm run build && npm --prefix site clean-install --progress=false && npm --prefix site run workers:dev",
    "workers:deploy": "npm run build && npm --prefix site clean-install --progress=false && npm --prefix site run workers:deploy",
    "workers:preview": "npm run build && npm --prefix site clean-install --progress=false && npm --prefix site run workers:preview"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.17",
    "terser": "^5.42.0"
  }
}
