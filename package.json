{
  "name": "basecoat",
  "version": "1.0.0-beta.2",
  "description": "shadcn/ui for the rest of us",
  "author": "hunvreus",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "components",
    "component library",
    "component system",
    "ui",
    "ui kit",
    "shadcn",
    "shadcn/ui",
    "tailwind",
    "tailwindcss",
    "css",
    "html",
    "jinja",
    "nunjucks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hunvreus/basecoat.git"
  },
  "bugs": {
    "url": "https://github.com/hunvreus/basecoat/issues"
  },
  "homepage": "https://github.com/hunvreus/basecoat#readme",
  "scripts": {
    "build": "node ./scripts/build.js",
    "docs:build": "npm run build && astro build",
    "docs:dev": "astro dev",
    "workers:dev": "npm run docs:build && wrangler dev",
    "workers:deploy": "npm run docs:build && wrangler deploy",
    "workers:preview": "npm run docs:build && wrangler versions upload"
  },
  "devDependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@tailwindcss/cli": "^4.1.17",
    "astro": "^6.4.6",
    "htmx.org": "^2.0.10",
    "lucide-static": "^1.17.0",
    "nunjucks": "^3.2.4",
    "prettier": "^3.5.3",
    "reallysimpledocs": "file:../reallysimpledocs",
    "tailwindcss": "^4.1.17",
    "terser": "^5.42.0",
    "wrangler": "^4.50.0"
  }
}
