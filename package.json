{
  "name": "basecoat",
  "version": "0.3.11",
  "description": "shadcn/ui for the rest of us",
  "author": "hunvreus",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "components",
    "component library",
    "component system",
    "ui",
    "ui kit",
    "shadcn",
    "shadcn/ui",
    "tailwind",
    "tailwindcss",
    "css",
    "html",
    "jinja",
    "nunjucks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hunvreus/basecoat.git"
  },
  "bugs": {
    "url": "https://github.com/hunvreus/basecoat/issues"
  },
  "homepage": "https://github.com/hunvreus/basecoat#readme",
  "scripts": {
    "build": "node ./scripts/build.js",
    "docs:build:css": "node ./scripts/build-docs-css.js",
    "docs:build": "npm run docs:build:css && eleventy",
    "docs:dev:css": "node ./scripts/build-docs-css.js --watch",
    "docs:dev:eleventy": "ELEVENTY_ENV=prod eleventy --serve",
    "docs:dev": "concurrently \"npm:docs:dev:css\" \"npm:docs:dev:eleventy\"",
    "workers:dev": "npm run docs:build && wrangler dev",
    "workers:deploy": "npm run docs:build && wrangler deploy",
    "workers:preview": "npm run docs:build && wrangler versions upload"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@grimlink/eleventy-plugin-lucide-icons": "^2.1.4",
    "@tailwindcss/cli": "^4.1.3",
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.3",
    "terser": "^5.42.0",
    "wrangler": "^4.50.0"
  }
}
