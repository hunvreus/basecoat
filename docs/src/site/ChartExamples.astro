---
import { Preview } from "reallysimpledocs/components";

const barCode = `<div class="h-[220px] [&_.chart]:h-full [&_.chart]:aspect-auto">
  <canvas id="visitors-chart" aria-label="Monthly visitors by device"></canvas>
</div>`;

const lineCode = `<div class="h-[220px] [&_.chart]:h-full [&_.chart]:aspect-auto">
  <canvas id="revenue-chart" aria-label="Revenue line chart"></canvas>
</div>`;

const stepCode = `<div class="h-[220px] [&_.chart]:h-full [&_.chart]:aspect-auto">
  <canvas id="queue-chart" aria-label="Support queue step chart"></canvas>
</div>`;

const stackedCode = `<div class="h-[220px] [&_.chart]:h-full [&_.chart]:aspect-auto">
  <canvas id="pipeline-chart" aria-label="Stacked pipeline bar chart"></canvas>
</div>`;

const donutCode = `<div class="h-[220px] [&_.chart]:h-full [&_.chart]:aspect-auto">
  <canvas id="traffic-chart" aria-label="Traffic source donut chart"></canvas>
</div>`;

const radarCode = `<div class="h-[260px] [&_.chart]:h-full [&_.chart]:aspect-auto">
  <canvas id="channel-chart" aria-label="Channel performance radar chart"></canvas>
</div>`;
---

<div class="grid gap-10">
  <section>
    <h3>Bar Chart - Multiple</h3>
    <Preview class="w-full" code={barCode}>
      <div class="h-[220px] w-full [&_.chart]:h-full [&_.chart]:aspect-auto">
        <canvas id="chart-example-visitors" aria-label="Monthly visitors by device"></canvas>
      </div>
    </Preview>
  </section>

  <section>
    <h3>Line Chart - Linear</h3>
    <Preview class="w-full" code={lineCode}>
      <div class="h-[220px] w-full [&_.chart]:h-full [&_.chart]:aspect-auto">
        <canvas id="chart-example-line" aria-label="Revenue line chart"></canvas>
      </div>
    </Preview>
  </section>

  <section>
    <h3>Line Chart - Step</h3>
    <Preview class="w-full" code={stepCode}>
      <div class="h-[220px] w-full [&_.chart]:h-full [&_.chart]:aspect-auto">
        <canvas id="chart-example-step" aria-label="Support queue step chart"></canvas>
      </div>
    </Preview>
  </section>

  <section>
    <h3>Bar Chart - Stacked</h3>
    <Preview class="w-full" code={stackedCode}>
      <div class="h-[220px] w-full [&_.chart]:h-full [&_.chart]:aspect-auto">
        <canvas id="chart-example-stacked" aria-label="Stacked pipeline bar chart"></canvas>
      </div>
    </Preview>
  </section>

  <section>
    <h3>Pie Chart - Donut</h3>
    <Preview class="w-full" code={donutCode}>
      <div class="h-[220px] w-full [&_.chart]:h-full [&_.chart]:aspect-auto">
        <canvas id="chart-example-donut" aria-label="Traffic source donut chart"></canvas>
      </div>
    </Preview>
  </section>

  <section>
    <h3>Radar Chart</h3>
    <Preview class="w-full" code={radarCode}>
      <div class="h-[260px] w-full [&_.chart]:h-full [&_.chart]:aspect-auto">
        <canvas id="chart-example-radar" aria-label="Channel performance radar chart"></canvas>
      </div>
    </Preview>
  </section>
</div>
